{
  "$schema": "https://json-schema.org/draft-04/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "output_filename_prefix": {
      "type": "string"
    },
    "export_formats": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "export_type": {
                "type": "string",
                "enum": [
                  "generate_axe_core_template_aware_file",
                  "axe_core_template_aware_leaderboard",
                  "raw_data"
                ]
              },
              "input_filename": {
                "type": "string"
              },
              "output_filename": {
                "type": "string"
              }
            },
            "required": [
              "enabled",
              "export_type",
              "input_filename",
              "output_filename"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "export_type": {
                "type": "string",
                "enum": [
                  "leaderboard"
                ]
              },
              "input_filename": {
                "type": "string"
              },
              "output_filename": {
                "type": "string"
              },
              "query": {
                "type": "string"
              }
            },
            "required": [
              "enabled",
              "export_type",
              "input_filename",
              "output_filename",
              "query"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "required": [
    "output_filename_prefix",
    "export_formats"
  ],
  "additionalProperties": false
}
